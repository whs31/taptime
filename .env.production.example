POSTGRES_DB=taptime
POSTGRES_USER=taptime
POSTGRES_PASSWORD=change-me-use-a-long-random-password

JWT_SECRET=change-me-use-a-long-random-secret

# Argon2 PHC hashes contain $ characters. In .env.production, wrap the value in
# single quotes so Docker Compose does not interpolate the hash fields:
# ADMIN_PASSWORD_HASH='$argon2id$v=19$m=19456,t=2,p=1$...$...'
ADMIN_PASSWORD_HASH=
ADMIN_TOKEN_TTL_SECONDS=28800
TRUST_PROXY_HEADERS=true

# This must be reachable by the user's browser, not just by Docker containers.
PUBLIC_API_URL=http://127.0.0.1:50051

# Defaults bind services to loopback for an external reverse proxy on the host.
WEB_BIND=127.0.0.1
WEB_PORT=3000
API_BIND=127.0.0.1
API_PORT=50051
